rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ================================================================
       HELPER FUNCTIONS
       ================================================================ */

    function isAuth() {
      return request.auth != null && request.auth.uid != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && userRole() == 'admin';
    }

    function isOwnUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function canReadUser(uid) {
      return isAdmin() || isOwnUser(uid);
    }

    function canWriteUser(uid) {
      return isAdmin() || isOwnUser(uid);
    }

    function isValidUserDoc() {
      return request.resource.data.keys().hasAll(['uid', 'email', 'display_name', 'church_id', 'role', 'created_at'])
        && request.resource.data.role in ['admin', 'member']
        && request.resource.data.church_id is string
        && request.resource.data.uid is string;
    }

    /* ================================================================
       USERS COLLECTION
       Members: read/write own doc only.
       Admins: read/write any user doc.
       ================================================================ */

    match /users/{userId} {
      allow read: if canReadUser(userId);
      allow create: if isOwnUser(userId) && isValidUserDoc();
      allow update: if canWriteUser(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid']));
      allow delete: if isAdmin();

      /* ---- User-isolated subcollections ---- */
      match /watch_progress/{docId} {
        allow read, write: if canWriteUser(userId);
      }

      match /saved_content/{docId} {
        allow read, write: if canWriteUser(userId);
      }

      match /song_requests/{docId} {
        allow read, write: if canWriteUser(userId);
      }

      match /devices/{deviceId} {
        allow read, write: if canWriteUser(userId);
      }

      match /tv_state/{docId} {
        allow read, write: if canWriteUser(userId);
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    /* ================================================================
       SHARED CHURCH CONTENT
       All authenticated users can read.
       Only admins can create, update, delete.
       ================================================================ */

    // Sermons / Events / Announcements — unified content store
    match /content/{contentId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();

      // Validate required fields on create
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['type', 'title', 'status', 'createdAt'])
        && request.resource.data.type in ['sermon', 'event', 'announcement', 'video']
        && request.resource.data.status in ['draft', 'published', 'archived'];
    }

    // Photo albums
    match /albums/{albumId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Gallery — individual photos within albums
    match /gallery/{photoId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Gallery photos (collection named gallery_photos)
    match /gallery_photos/{photoId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Album entries (photo entries within albums)
    match /album_entries/{entryId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // YouTube channel info
    match /youtube_channel/{channelId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // YouTube videos library
    match /youtube_videos/{videoId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // YouTube sermon series
    match /youtube_series/{seriesId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // YouTube live status (used for live broadcast detection)
    match /youtube_live/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Videos (standalone — may also appear in /content)
    match /videos/{videoId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Sermon series
    match /series/{seriesId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Events (standalone — may also appear in /content)
    match /events/{eventId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Announcements (standalone — may also appear in /content)
    match /announcements/{announcementId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Banners (homepage hero banners)
    match /banners/{bannerId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // TV Chat — real-time messages during broadcasts
    match /tv_chat/{msgId} {
      allow read, create: if isAuth();
      allow delete: if isAdmin();
    }

    // TV Prayer Requests — community prayer during broadcasts
    match /tv_prayers/{reqId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['request', 'createdAt'])
        && request.resource.data.request is string
        && request.resource.data.request.size() > 0;
      allow delete: if isAdmin();
    }

    // TV Broadcast schedule (generated by admin)
    match /tv_broadcast/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // TV Playlists (scheduled playlists for TV)
    match /tv_playlists/{plId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Radio schedule / now-playing metadata
    match /radio/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Radio station configurations
    match /radioStations/{stationId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Meetings (LiveKit audio meetings)
    match /meetings/{meetingId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Payment methods — admins CRUD, members can read enabled ones
    match /payment_methods/{methodId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Giving records — members can create their own, admins can CRUD all
    match /giving/{givingId} {
      allow read: if isAdmin() || (isAuth() && resource.data.memberId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['memberId', 'memberName', 'amount', 'paymentMethodId', 'paymentMethodLabel', 'confirmationCode', 'date', 'createdAt'])
        && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // AI Data configuration (settings, admins, menu config)
    match /aiData/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // AI Sermons
    match /ai_sermons/{sermonId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // AI Prayers — any authenticated user can submit, admins manage
    match /ai_prayers/{prayerId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['name', 'text', 'createdAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0;
      allow update, delete: if isAdmin();
    }

    // AI Ministries
    match /ai_ministries/{ministryId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // AI Events
    match /ai_events/{eventId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // AI Conversations
    match /ai_conversations/{conversationId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // AI Transactions
    match /ai_transactions/{transactionId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    /* ================================================================
       DENY ALL OTHER ACCESS
       ================================================================ */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
